pipeline {
    agent any

    triggers {
        gitlab(
            triggerOnPush: false,
            triggerOnMergeRequest: false,
            triggerOnAcceptedMergeRequest: true,
            branchFilterType: 'NameBasedFilter',
            includeBranchesSpec: 'master'
        )
    }

    environment {
        BACKEND_IMAGE = 'oh-my-guide-backend:latest'
        COMPOSE_DIR   = 'infra/application-server'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Detect Changes') {
            steps {
                script {
                    def changedFiles = sh(
                        script: 'git diff --name-only HEAD~1 HEAD',
                        returnStdout: true
                    ).trim()
                    echo "Changed files:\n${changedFiles}"
                    env.BACKEND_CHANGED = changedFiles.split('\n').any { it.startsWith('backend/') } ? 'true' : 'false'
                }
            }
        }

        stage('Build Backend Image') {
            when {
                environment name: 'BACKEND_CHANGED', value: 'true'
            }
            steps {
                sh 'docker build -t $BACKEND_IMAGE ./backend'
            }
        }

        stage('Deploy Backend') {
            when {
                environment name: 'BACKEND_CHANGED', value: 'true'
            }
            steps {
                withCredentials([file(credentialsId: 'backend-env-file', variable: 'ENV_FILE')]) {
                    sh '''
                        cp $ENV_FILE ./backend/.env
                        cd $COMPOSE_DIR
                        docker compose -f docker-compose.backend.yml down || true
                        docker compose -f docker-compose.backend.yml up -d
                    '''
                }
            }
        }
    }

    post {
        success {
            withCredentials([string(credentialsId: 'mattermost-webhook-url', variable: 'WEBHOOK_URL')]) {
                script {
                    def msg = "✅ **Backend 배포 성공!!**\n- Job: ${env.JOB_NAME}\n- Build: #${env.BUILD_NUMBER}\n- Branch: ${env.GIT_BRANCH}"
                    def payload = groovy.json.JsonOutput.toJson([text: msg])
                    sh "curl -s -X POST \"\$WEBHOOK_URL\" -H 'Content-Type: application/json' -d '${payload}'"
                }
            }
        }
        failure {
            withCredentials([string(credentialsId: 'mattermost-webhook-url', variable: 'WEBHOOK_URL')]) {
                script {
                    def msg = "❌ **Backend 배포 실패!!**\n- Job: ${env.JOB_NAME}\n- Build: #${env.BUILD_NUMBER}\n- Branch: ${env.GIT_BRANCH}\n- URL: ${env.BUILD_URL}"
                    def payload = groovy.json.JsonOutput.toJson([text: msg])
                    sh "curl -s -X POST \"\$WEBHOOK_URL\" -H 'Content-Type: application/json' -d '${payload}'"
                }
            }
        }
    }
}
