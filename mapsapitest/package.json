{
  "name": "odsay-route-finder",
  "version": "1.0.0",
  "description": "ODsay 대중교통 길찾기 앱 (TypeScript)",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "esbuild src/client/app.ts --bundle --outfile=public/app.js --target=es2020 --format=iife",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/server.js",
    "dev": "concurrently \"tsc -p tsconfig.server.json --watch\" \"esbuild src/client/app.ts --bundle --outfile=public/app.js --target=es2020 --format=iife --watch\" \"nodemon --watch dist dist/server/server.js\""
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.19.11",
    "nodemon": "^3.0.2",
    "typescript": "^5.3.3"
  }
}
